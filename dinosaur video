    {
      "parameters": {
        "jsCode": "const pexelsData = $input.first().json;\nconst scriptData = $('Parse Script JSON').item.json;\n\nconst videos = pexelsData.videos;\nif (!videos || videos.length === 0) {\n  throw new Error('No videos found on Pexels for this topic: ' + scriptData.topic);\n}\n\nconst getUrl = (index) => {\n  const v = videos[index % videos.length];\n  const file = v.video_files.find(f => f.quality === 'hd') ||\n               v.video_files.find(f => f.quality === 'sd') ||\n               v.video_files[0];\n  return file.link;\n};\n\nreturn [{\n  json: {\n    videoUrl1: getUrl(0),\n    videoUrl2: getUrl(1),\n    videoUrl3: getUrl(2),\n    videoUrl4: getUrl(3),\n    title: scriptData.title,\n    description: scriptData.description,\n    tags: scriptData.tags,\n    topic: scriptData.topic,\n    scene1: scriptData.scene1,\n    scene2: scriptData.scene2,\n    scene3: scriptData.scene3,\n    scene4: scriptData.scene4\n  }\n}];"
      },
      "id": "4370da9e-374a-4279-b1e7-d465005135c3",
