    {
      "parameters": {
        "jsCode": "const topics = [\n  '5 life hacks you wish you knew earlier',\n  'Mind-blowing AI facts in 60 seconds',\n  'History of the internet in 60 seconds',\n  '3 habits of millionaires',\n  'Space facts that will blow your mind',\n  'Python tips every beginner must know',\n  'Why 99% of people fail at their goals',\n  'The science of sleep in 60 seconds'\n];\n\nconst topic = topics[Math.floor(Math.random() * topics.length)];\nreturn [{ json: { topic } }];"
      },
