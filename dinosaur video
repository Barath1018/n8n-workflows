    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst content = raw.choices[0].message.content;\n\nlet parsed;\ntry {\n  const clean = content.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch (e) {\n  parsed = {\n    title: 'Amazing Facts You Never Knew',\n    description: 'Watch this to learn something new today.',\n    tags: ['shorts', 'facts', 'viral', 'trending', 'learn'],\n    scene1: 'Did you know these amazing facts?',\n    scene2: 'First incredible point you need to know.',\n    scene3: 'Second mind-blowing fact revealed.',\n    scene4: 'Third amazing truth. Follow for more!'\n  };\n}\n\nparsed.topic = $('Pick Topic').item.json.topic || '';\n\nreturn [{ json: parsed }];"
      },
