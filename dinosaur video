    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer your-api-key"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a viral YouTube Shorts scriptwriter. Always respond with a JSON object only. No markdown, no explanation, no code fences.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a 60-second YouTube Shorts script about: {{ $json.topic }}. Return ONLY a JSON object with these fields: title (catchy, under 60 chars, no hashtags), description (2-3 sentences for YouTube description), tags (array of 5 strings), scene1 (hook sentence, max 20 words), scene2 (point 1, max 20 words), scene3 (point 2, max 20 words), scene4 (point 3 + end with Follow for more!, max 25 words)\"\n    }\n  ],\n  \"temperature\": 0.8,\n  \"max_tokens\": 600\n}",
        "options": {}
      },
      "id": "554fa6c0-897d-45e6-ac5b-cca28ceb5c45",
      "name": "Generate Script",
