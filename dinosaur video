      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst v1 = data.videoUrl1 || 'NO_VIDEO_URL';\nconst v2 = data.videoUrl2 || 'NO_VIDEO_URL';\nconst v3 = data.videoUrl3 || 'NO_VIDEO_URL';\nconst v4 = data.videoUrl4 || 'NO_VIDEO_URL';\n\nconst s1 = data.scene1 || 'Did you know this amazing fact?';\nconst s2 = data.scene2 || 'Here is the first point.';\nconst s3 = data.scene3 || 'Here is the second point.';\nconst s4 = data.scene4 || 'Follow for more!';\n\nconst body = JSON.stringify({\n  template_id: \"d35b1f00-91f3-46bb-9025-1dbeb1f6ff75\",\n  modifications: {\n    \"Image-1.source\": v1,\n    \"Voiceover-1.text\": s1,\n    \"Image-2.source\": v2,\n    \"Voiceover-2.text\": s2,\n    \"Image-3.source\": v3,\n    \"Voiceover-3.text\": s3,\n    \"Image-4.source\": v4,\n    \"Voiceover-4.text\": s4\n  }\n});\n\nreturn [{\n  json: {\n    title: data.title || 'Untitled',\n    description: data.description || '',\n    tags: data.tags || [],\n    topic: data.topic || '',\n    creatomateBody: body\n  }\n}];"
